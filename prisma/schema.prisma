generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(user)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Publisher {
  id                 String      @id @default(uuid())
  name               String
  slug               String      @unique
  logoUrl            String      @default("")
  description        String      @default("")
  websiteUrl         String      @default("")
  instagramUrl       String      @default("")
  tiktokUrl          String      @default("")
  email              String      @default("")
  submissionEmail    String      @default("")
  isImprint          Boolean     @default(false)
  parentId           String?
  parent             Publisher?  @relation("ImprintParent", fields: [parentId], references: [id])
  imprints           Publisher[] @relation("ImprintParent")
  collaborationInfo  String      @default("")
  collaborationUrl   String      @default("")
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

enum Role {
  user
  publisher
  moderator
  admin
}
